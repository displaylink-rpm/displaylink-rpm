 3 files changed, 77 insertions(+), 5 deletions(-)

diff --git a/ci/build_against_kernel b/ci/build_against_kernel
index 1eed37bf..75ed061f 100755
--- a/ci/build_against_kernel
+++ b/ci/build_against_kernel
@@ -237,7 +237,7 @@ build_one() { # KVER
 
   local src_dir
   local KTAG=v${KVER}
-  local extra_cflags="-DCONFIG_FB"
+  local extra_cflags="-DCONFIG_FB -DCONFIG_DRM_TTM_HELPER"
   if [ "${KVER}" == "master" ]; then
     KTAG="origin/master"
   else
diff --git a/module/Kconfig b/module/Kconfig
index 80d87659..4b8a6dec 100644
--- a/module/Kconfig
+++ b/module/Kconfig
