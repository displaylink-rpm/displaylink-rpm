Subject: [PATCH 18/28] debugfs: add function to measure drm_framebuffer copy
 time

---
 module/evdi_painter.c | 66 ++++++++++++++++++++++++++++++++++++++++++-
 1 file changed, 65 insertions(+), 1 deletion(-)

diff --git a/module/evdi_painter.c b/module/evdi_painter.c
index eb7e1ec7..fd833c54 100644
--- a/module/evdi_painter.c
+++ b/module/evdi_painter.c
@@ -14,6 +14,7 @@
 #include <drm/drm_file.h>
